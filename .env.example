# ===========================================================================
# Environment Variables
#
# Copy this file to .env and fill in real values for local dev. For
# production, set the same keys in Vercel → Project Settings →
# Environment Variables (Production + Preview).
# ===========================================================================

# --- MySQL connection (used by /api/employee/[id]) ------------------------
DB_HOST=137.220.58.223
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=EVOLUTRA_EVENT_DB
DB_PORT=3306

# --- Browser-facing API base URL -----------------------------------------
# Unset: use the in-process Vite plugin route at /api/employee
#   (works in `npm run dev` — same port, no extra process).
# Set: full URL when hosting the React app and API on different origins,
#   e.g. https://api.evolutra.com/api/employee
# VITE_PROFILE_API=/api/employee
